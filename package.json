{
  "name": "quran-web-app-v2",
  "version": "1.0.0",
  "private": true,
  "description": "Quran Web Application technical assessment built with Next.js SSG, TypeScript, Tailwind CSS, and Hono-Bun.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "cd apps/api && bun run dev",
    "build": "npm --workspace apps/web run build",
    "start": "npm --workspace apps/web run start",
    "lint": "npm --workspace apps/web run lint"
  },
  "keywords": [
    "quran",
    "nextjs",
    "typescript",
    "tailwind",
    "hono",
    "bun"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0"
  }
}
